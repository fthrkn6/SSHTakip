# ============================================
# FLASK CONFIGURATION
# ============================================
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=0

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite (Development)
DATABASE_URL=sqlite:///cmms.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost:5432/cmms_db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# ============================================
# CACHE & REDIS CONFIGURATION
# ============================================
REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TIMEOUT=300
REDIS_PASSWORD=

# ============================================
# CELERY CONFIGURATION (Async Tasks)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=1800

# ============================================
# EMAIL CONFIGURATION (Reports & Notifications)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@example.com

# ============================================
# APPLICATION SETTINGS
# ============================================
MAX_CONTENT_LENGTH=52428800  # 50MB
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=xlsx,csv,json,pdf,doc,docx,jpg,png,jpeg
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_HTTPONLY=1
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=10

# ============================================
# SECURITY
# ============================================
SENTRY_DSN=
BCRYPT_LOG_ROUNDS=12

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_REDIS_CACHE=1
FEATURE_ASYNC_TASKS=0
FEATURE_EMAIL_REPORTS=0
FEATURE_DARK_MODE=1

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
SENTRY_ENABLED=0
MONITORING_ENABLED=0
